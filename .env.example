# ─────────────────────────────────────────────────
# Portfolio aka — Environment Variables
# Copy file ini ke .env dan isi nilainya
# JANGAN commit file .env ke repo
# ─────────────────────────────────────────────────

# Admin Dashboard Password
# Default fallback: "aka" (ganti ini di production!)
ADMIN_PASSWORD=aka

# Session Secret — string acak panjang untuk tanda tangan token
# Buat dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=ganti-dengan-string-acak-panjang-sekali

# Email (Gmail) — untuk notifikasi contact form
# Gunakan App Password dari Google Account (bukan password utama!)
# Google Account > Security > 2-Step Verification > App Passwords
EMAIL_USER=email@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_RECIPIENT=email@gmail.com
